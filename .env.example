# ────────────────────────────────────────────────────────────
# paper-qa-lang 环境变量配置
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ────────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────
# 选择 provider: anthropic / openai / google
# 至少配置所选 provider 对应的 API_KEY

# Anthropic (claude-sonnet-4-6, deepseek-v4-flash 等兼容接口)
ANTHROPIC_API_KEY=sk-your-api-key-here
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# OpenAI (gpt-4o, qwen 等兼容接口)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com

# 默认模型名称 (可被 Settings 覆盖)
MODEL_NAME=deepseek-v4-flash

# ── LangGraph Checkpoint ───────────────────────────────────
# PostgreSQL 连接串，用于持久化 LangGraph 会话状态
CHECKPOINT_DB=postgresql://user:password@localhost:5432/mydb

# ── MCP Services ──────────────────────────────────────────
# Unpaywall 邮箱 (获取开放获取 PDF 链接时需要)
UNPAYWALL_EMAIL=your-email@example.com

# MCP 服务日志级别 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=WARNING

# ── HuggingFace ───────────────────────────────────────────
# Transformers 模型缓存路径
TRANSFORMERS_CACHE=D:/workplace/models
HF_HOME=D:/workplace/models
HF_DATASETS_CACHE=D:/workplace/models/datasets

# 离线模式 (1 = 仅使用本地缓存, 0 或不设置 = 允许联网)
TRANSFORMERS_OFFLINE=0
HF_HUB_OFFLINE=0

# ── 网络代理 (可选) ───────────────────────────────────────
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1
